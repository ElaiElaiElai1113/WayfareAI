{
  "name": "wayfare-ai",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "worker"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:client dev:worker",
    "dev:client": "npm --prefix client run dev",
    "dev:worker": "npm --prefix worker run dev",
    "build": "npm-run-all build:client build:worker",
    "build:client": "npm --prefix client run build",
    "build:worker": "npm --prefix worker run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

